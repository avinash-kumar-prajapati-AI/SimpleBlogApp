---
/**
 * Navbar.astro — sticky IBM-styled navigation bar
 */
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/search', label: 'Search' },
  { href: '/categories', label: 'Categories' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav class="navbar" role="navigation" aria-label="Main navigation">
  <div class="container navbar__inner">
    <!-- Logo / Brand -->
    <a href="/" class="navbar__brand" aria-label="AvinashBlog home">
      <span class="navbar__logo-text">AvinashBlog</span>
      <span class="navbar__logo-dot" aria-hidden="true">.</span>
    </a>

    <!-- Desktop links -->
    <ul class="navbar__links" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`navbar__link ${currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'navbar__link--active' : ''}`}
            aria-current={currentPath === href ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      class="navbar__toggle"
      id="nav-toggle"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Toggle navigation menu"
    >
      <span class="navbar__toggle-bar"></span>
      <span class="navbar__toggle-bar"></span>
      <span class="navbar__toggle-bar"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
    <ul role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`mobile-menu__link ${currentPath === href ? 'mobile-menu__link--active' : ''}`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-h);
  }

  .navbar__brand {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--ibm-white);
    letter-spacing: -0.02em;
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 1px;
  }
  .navbar__brand:hover { color: var(--ibm-blue-50); text-decoration: none; }
  .navbar__logo-dot { color: var(--ibm-blue-50); font-size: 1.4em; line-height: 0; }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
  }

  .navbar__link {
    display: block;
    padding: var(--space-2) var(--space-3);
    color: var(--ibm-gray-30);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    border-bottom: 2px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    text-decoration: none;
  }
  .navbar__link:hover { color: var(--ibm-white); text-decoration: none; }
  .navbar__link--active {
    color: var(--ibm-white);
    border-bottom-color: var(--ibm-blue-50);
  }

  .navbar__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .navbar__toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ibm-gray-30);
    border-radius: 1px;
    transition: transform var(--transition-normal), opacity var(--transition-fast);
  }

  /* Mobile */
  .mobile-menu {
    display: none;
    background: var(--ibm-gray-90);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--ibm-gray-80);
  }
  .mobile-menu.open { display: block; }
  .mobile-menu__link {
    display: block;
    padding: var(--space-3) var(--space-6);
    color: var(--ibm-gray-30);
    font-size: var(--text-base);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .mobile-menu__link:hover { background: var(--ibm-gray-80); color: var(--ibm-white); text-decoration: none; }
  .mobile-menu__link--active { color: var(--ibm-white); border-left: 3px solid var(--ibm-blue-50); }

  @media (max-width: 768px) {
    .navbar__links { display: none; }
    .navbar__toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
    }
  });
</script>
