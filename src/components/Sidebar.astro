---
/**
 * Sidebar.astro — right sidebar: categories, recent articles, tag cloud
 * Default: visible on desktop, hidden on mobile
 * Toggle button always visible; click-outside closes on mobile
 */
interface SidebarCategory { name: string; count: number; }
interface RecentArticle { slug: string; category: string; title: string; modified_date: string; }
interface Props {
  categories?: SidebarCategory[];
  recentArticles?: RecentArticle[];
  tags?: string[];
}

const { categories = [], recentArticles = [], tags = [] } = Astro.props;
---

<!-- Toggle button (always visible, positioned relative to sidebar trigger) -->
<button
  class="sidebar-toggle"
  id="sidebar-toggle"
  aria-controls="sidebar"
  aria-expanded="true"
  aria-label="Toggle sidebar"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <rect x="3" y="3" width="18" height="18" rx="2"/>
    <line x1="9" y1="3" x2="9" y2="21"/>
  </svg>
</button>

<aside class="sidebar" id="sidebar" aria-label="Sidebar">
  <!-- Top categories -->
  {categories.length > 0 && (
    <section class="sidebar__section" aria-labelledby="sidebar-cats-heading">
      <h3 class="sidebar__heading" id="sidebar-cats-heading">Categories</h3>
      <ul class="sidebar__list" role="list">
        {categories.map(({ name, count }) => (
          <li>
            <a
              href={`/search?q=${encodeURIComponent(`@category ${name}`)}`}
              class="sidebar__cat-link"
            >
              <span>{name}</span>
              <span class="sidebar__count">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Ad slot -->
  <div class="ad-unit ad-unit--sidebar" id="sidebar-ad-slot" aria-label="Advertisement" role="complementary">
    <span>Ad</span>
  </div>

  <!-- Recent articles -->
  {recentArticles.length > 0 && (
    <section class="sidebar__section" aria-labelledby="sidebar-recent-heading">
      <h3 class="sidebar__heading" id="sidebar-recent-heading">Recent Articles</h3>
      <ul class="sidebar__list" role="list">
        {recentArticles.map(({ slug, category, title, modified_date }) => (
          <li class="sidebar__recent-item">
            <a href={`/articles/${category}/${slug}`} class="sidebar__recent-link">
              {title}
            </a>
            <time class="sidebar__date" datetime={modified_date}>
              {new Date(modified_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Tag cloud -->
  {tags.length > 0 && (
    <section class="sidebar__section" aria-labelledby="sidebar-tags-heading">
      <h3 class="sidebar__heading" id="sidebar-tags-heading">Tags</h3>
      <div class="sidebar__tags" role="list" aria-label="Tag cloud">
        {tags.slice(0, 30).map((tag) => (
          <a
            href={`/search?q=${encodeURIComponent(`@tag ${tag}`)}`}
            class="tag-pill"
            role="listitem"
          >
            #{tag}
          </a>
        ))}
      </div>
    </section>
  )}
</aside>

<style>
  .sidebar-toggle {
    position: fixed;
    right: var(--space-4);
    top: calc(var(--nav-h) + var(--space-4));
    z-index: var(--z-sidebar);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    transition: color var(--transition-fast), background var(--transition-fast);
    cursor: pointer;
  }
  .sidebar-toggle:hover { color: var(--color-primary); background: var(--color-primary-light); }

  /* Hide toggle on large screens — sidebar always visible */
  @media (min-width: 1024px) {
    .sidebar-toggle { display: none; }
  }

  .sidebar {
    width: var(--sidebar-w);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .sidebar__section { display: flex; flex-direction: column; gap: var(--space-3); }

  .sidebar__heading {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar__list { display: flex; flex-direction: column; gap: var(--space-1); list-style: none; }

  .sidebar__cat-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .sidebar__cat-link:hover { background: var(--color-primary-light); color: var(--color-primary); text-decoration: none; }

  .sidebar__count {
    font-size: var(--text-xs);
    color: var(--ibm-gray-60);
    background: var(--ibm-gray-20);
    padding: 1px 6px;
    border-radius: var(--radius-pill);
  }

  .sidebar__recent-item { display: flex; flex-direction: column; gap: var(--space-1); padding: var(--space-2) 0; border-bottom: 1px solid var(--color-border); }
  .sidebar__recent-item:last-child { border-bottom: none; }
  .sidebar__recent-link {
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: var(--leading-snug);
    transition: color var(--transition-fast);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sidebar__recent-link:hover { color: var(--color-primary); }
  .sidebar__date { font-size: var(--text-xs); color: var(--color-text-secondary); }

  .sidebar__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }

  /* Mobile: sidebar is off-canvas */
  @media (max-width: 1023px) {
    .sidebar {
      position: fixed;
      right: 0;
      top: var(--nav-h);
      bottom: 0;
      width: min(var(--sidebar-w), 85vw);
      background: var(--color-bg);
      border-left: 1px solid var(--color-border);
      overflow-y: auto;
      padding: var(--space-6);
      z-index: calc(var(--z-sidebar) - 1);
      transform: translateX(100%);
      transition: transform var(--transition-normal);
      box-shadow: var(--shadow-lg);
    }
    .sidebar.open {
      transform: translateX(0);
    }
  }
</style>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('sidebar');

  function open() {
    sidebar?.classList.add('open');
    toggle?.setAttribute('aria-expanded', 'true');
    sidebar?.removeAttribute('aria-hidden');
  }
  function close() {
    sidebar?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    sidebar?.setAttribute('aria-hidden', 'true');
  }

  toggle?.addEventListener('click', () => {
    sidebar?.classList.contains('open') ? close() : open();
  });

  // Click outside closes on mobile
  document.addEventListener('click', (e) => {
    if (window.innerWidth >= 1024) return;
    if (!sidebar?.contains(e.target as Node) && !toggle?.contains(e.target as Node)) {
      close();
    }
  });

  // Initial state: open on desktop
  if (window.innerWidth < 1024) close();
</script>
