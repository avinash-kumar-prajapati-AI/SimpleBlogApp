---
/**
 * index.astro — Homepage: hero + recent articles + ad slots
 * All content fetched from GitHub at build time. No Node.js fs/path used.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import AdUnit from '../components/AdUnit.astro';
import SearchBar from '../components/SearchBar.astro';
import TagPill from '../components/TagPill.astro';
import { fetchAllArticles, fetchVisibility, fetchDrafts } from '../lib/github';
import { parseArticle } from '../lib/parseArticles';
import type { Article } from '../lib/parseArticles';

// ── Fetch content at build time (no fs/path) ──────────
let articles: Article[] = [];
let categories: string[] = [];
let popularTags: string[] = [];

try {
  const [rawArticles, { visible }, drafts] = await Promise.all([
    fetchAllArticles(),
    fetchVisibility(),
    fetchDrafts(),
  ]);

  articles = rawArticles
    .filter((r) => !drafts.has(r.slug))
    .map((r) => parseArticle(r.raw, r.slug, r.category))
    .filter((a) => !a.frontmatter.draft)
    .filter((a) => visible.length === 0 || visible.includes(a.category))
    .sort((a, b) =>
      new Date(b.frontmatter.modified_date).getTime() -
      new Date(a.frontmatter.modified_date).getTime()
    );

  categories = [...new Set(articles.map((a) => a.category))];

  const tagCounts = new Map<string, number>();
  articles.forEach((a) =>
    a.frontmatter.tags.forEach((t) =>
      tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1)
    )
  );
  popularTags = [...tagCounts.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, 10)
    .map(([t]) => t);
} catch (e) {
  console.warn('index.astro: could not fetch articles:', e);
}

const recentArticles = articles.slice(0, 9);
const featuredArticle = articles[0];
---

<BaseLayout title="AvinashBlog" description="Personal blog on software engineering, AI, cloud, and developer tooling.">

  <!-- ── Hero ─────────────────────────────────────── -->
  <section class="hero" aria-label="Hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <p class="hero__eyebrow">Welcome to</p>
        <h1 class="hero__title">AvinashBlog<span class="hero__dot" aria-hidden="true">.</span></h1>
        <p class="hero__tagline">Software engineering · AI · Cloud · Developer tooling</p>
        <div class="hero__search">
          <SearchBar placeholder="Search articles, @tag react, @category ai..." />
        </div>
        {categories.length > 0 && (
          <div class="hero__categories" aria-label="Browse categories">
            {categories.map((cat) => <TagPill label={cat} type="category" />)}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Hero Ad -->
  <div class="container ad-wrap">
    <AdUnit size="banner" id="hero-ad" />
  </div>

  <!-- ── Featured Article ──────────────────────────── -->
  {featuredArticle && (
    <section class="container featured-section" aria-label="Featured article">
      <h2 class="section-heading">Featured</h2>
      <a href={`/articles/${featuredArticle.category}/${featuredArticle.slug}`} class="featured-card card">
        <div class="featured-card__body">
          <div class="featured-card__meta">
            <TagPill label={featuredArticle.category} type="category" />
            <span class="featured-card__date">
              {new Date(featuredArticle.frontmatter.modified_date).toLocaleDateString('en-US', {
                year: 'numeric', month: 'long', day: 'numeric',
              })}
            </span>
          </div>
          <h3 class="featured-card__title">{featuredArticle.frontmatter.title}</h3>
          <p class="featured-card__desc">{featuredArticle.frontmatter.description}</p>
          <span class="btn btn-primary featured-card__cta">Read Article →</span>
        </div>
        {featuredArticle.frontmatter.thumbnail && (
          <div class="featured-card__thumb">
            <img
              src={featuredArticle.frontmatter.thumbnail}
              alt={featuredArticle.frontmatter.title}
              width="800" height="450"
              loading="eager"
            />
          </div>
        )}
      </a>
    </section>
  )}

  <!-- ── Recent Articles ───────────────────────────── -->
  <section class="container articles-section" aria-label="Recent articles">
    <div class="section-header">
      <h2 class="section-heading">Recent Articles</h2>
      <a href="/search" class="btn btn-ghost">View all →</a>
    </div>

    {recentArticles.length > 0 ? (
      <>
        <div class="article-grid">
          {recentArticles.slice(0, 3).map((a, i) => (
            <ArticleCard
              slug={a.slug} category={a.category}
              title={a.frontmatter.title} description={a.frontmatter.description}
              tags={a.frontmatter.tags} modified_date={a.frontmatter.modified_date}
              thumbnail={a.frontmatter.thumbnail} readingTime={a.readingTime} index={i}
            />
          ))}
        </div>

        <div class="ad-wrap"><AdUnit size="banner" id="mid-feed-ad-1" /></div>

        <div class="article-grid">
          {recentArticles.slice(3, 6).map((a, i) => (
            <ArticleCard
              slug={a.slug} category={a.category}
              title={a.frontmatter.title} description={a.frontmatter.description}
              tags={a.frontmatter.tags} modified_date={a.frontmatter.modified_date}
              thumbnail={a.frontmatter.thumbnail} readingTime={a.readingTime} index={i}
            />
          ))}
        </div>

        <div class="ad-wrap"><AdUnit size="banner" id="mid-feed-ad-2" /></div>

        <div class="article-grid">
          {recentArticles.slice(6).map((a, i) => (
            <ArticleCard
              slug={a.slug} category={a.category}
              title={a.frontmatter.title} description={a.frontmatter.description}
              tags={a.frontmatter.tags} modified_date={a.frontmatter.modified_date}
              thumbnail={a.frontmatter.thumbnail} readingTime={a.readingTime} index={i}
            />
          ))}
        </div>
      </>
    ) : (
      <div class="empty-state">
        <p>No articles yet. Check back soon!</p>
        <a href="/about" class="btn btn-ghost">About this blog →</a>
      </div>
    )}
  </section>

  <!-- ── Popular Tags ──────────────────────────────── -->
  {popularTags.length > 0 && (
    <section class="container tags-section" aria-labelledby="popular-tags-heading">
      <h2 class="section-heading" id="popular-tags-heading">Popular Tags</h2>
      <div class="tags-cloud">
        {popularTags.map((tag) => <TagPill label={tag} type="tag" />)}
      </div>
    </section>
  )}

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────── */
  .hero {
    background: var(--ibm-gray-100);
    color: var(--ibm-white);
    padding: var(--space-20) 0 var(--space-16);
    background-image:
      linear-gradient(var(--ibm-gray-90) 1px, transparent 1px),
      linear-gradient(90deg, var(--ibm-gray-90) 1px, transparent 1px);
    background-size: 40px 40px;
    background-position: -1px -1px;
    animation: hero-reveal 0.6s cubic-bezier(0.42, 0, 0.58, 1) both;
  }
  @keyframes hero-reveal {
    from { opacity: 0; transform: translateY(-12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero__inner { max-width: 800px; }
  .hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--ibm-blue-50);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }
  .hero__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: var(--weight-bold);
    color: var(--ibm-white);
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }
  .hero__dot { color: var(--ibm-blue-50); }
  .hero__tagline {
    font-size: var(--text-lg);
    color: var(--ibm-gray-30);
    margin-bottom: var(--space-8);
  }
  .hero__search { max-width: 640px; margin-bottom: var(--space-6); }
  .hero__categories { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .hero__categories .tag-pill {
    background: rgba(255,255,255,0.08);
    color: var(--ibm-gray-10);
    border-color: rgba(255,255,255,0.15);
  }
  .hero__categories .tag-pill:hover {
    background: var(--ibm-blue-60);
    border-color: var(--ibm-blue-60);
    color: var(--ibm-white);
  }

  /* ── Sections ──────────────────────────────────── */
  .featured-section,
  .articles-section,
  .tags-section {
    padding-top: var(--space-12);
    padding-bottom: var(--space-6);
  }
  .ad-wrap { padding-top: var(--space-6); }

  .section-heading {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-6);
  }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }
  .section-header .section-heading { margin-bottom: 0; }

  /* ── Featured card ──────────────────────────────── */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    animation: card-enter 0.5s cubic-bezier(0.42, 0, 0.58, 1) 0.1s both;
  }
  @media (min-width: 768px) {
    .featured-card { grid-template-columns: 1fr 1fr; }
  }
  .featured-card:hover { text-decoration: none; }

  @keyframes card-enter {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .featured-card__body {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
  }
  .featured-card__meta { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .featured-card__date { font-size: var(--text-sm); color: var(--color-text-secondary); }
  .featured-card__title { font-size: var(--text-2xl); font-weight: var(--weight-bold); line-height: var(--leading-snug); }
  .featured-card__desc { color: var(--color-text-secondary); line-height: var(--leading-relaxed); }
  .featured-card__cta { align-self: flex-start; }

  .featured-card__thumb { overflow: hidden; }
  .featured-card__thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease-out;
  }
  .featured-card:hover .featured-card__thumb img { transform: scale(1.03); }

  /* ── Tags cloud ─────────────────────────────────── */
  .tags-cloud { display: flex; flex-wrap: wrap; gap: var(--space-2); }

  /* ── Empty state ────────────────────────────────── */
  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    color: var(--color-text-secondary);
  }
</style>
